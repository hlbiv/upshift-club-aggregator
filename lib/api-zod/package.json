{
  "name": "@hlbiv/api-zod",
  "version": "0.4.0",
  "description": "Orval-generated Zod validators and TypeScript types for the Upshift Data API (youth soccer club graph).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    }
  },
  "files": [
    "dist",
    "scripts/fix-esm-extensions.mjs"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/fix-esm-extensions.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hlbiv/upshift-data.git",
    "directory": "lib/api-zod"
  }
}
