modules = ["nodejs-24", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[deployment.scheduledJobs]]
name = "retention-prune"
cron = "0 2 * * *"
command = "cd scraper && python3 run.py --rollup retention-prune"

[nix]
channel = "stable-25_05"
packages = ["gitFull", "glibcLocales", "playwright-driver", "rapidfuzz-cpp", "taskflow", "xcodebuild", "zlib"]
