modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[deployment.scheduledJobs]]
name = "retention-prune"
cron = "0 2 * * *"
command = "cd scraper && python3 run.py --rollup retention-prune"

[[deployment.scheduledJobs]]
name = "nightly-canonical-club-linker"
cron = "0 3 * * *"
command = "cd scraper && python3 run.py --source link-canonical-clubs"

[[deployment.scheduledJobs]]
name = "nightly-canonical-school-linker"
cron = "30 3 * * *"
command = "cd scraper && python3 run.py --source link-canonical-schools"

[[deployment.scheduledJobs]]
name = "nightly-nav-leaked-names-detect"
cron = "35 3 * * *"
command = "cd scraper && python3 run.py --source nav-leaked-names-detect"

[[deployment.scheduledJobs]]
name = "nightly-numeric-only-names-detect"
cron = "40 3 * * *"
command = "cd scraper && python3 run.py --source numeric-only-names-detect"

[[deployment.scheduledJobs]]
name = "daily-club-results-rollup"
cron = "0 4 * * *"
command = "cd scraper && python3 run.py --rollup club-results"

[[deployment.scheduledJobs]]
name = "daily-scrape-health-rollup"
cron = "0 5 * * *"
command = "cd scraper && python3 run.py --rollup scrape-health"

[nix]
channel = "stable-25_05"
packages = ["gitFull", "glibcLocales", "playwright-driver", "rapidfuzz-cpp", "taskflow", "xcodebuild", "zlib"]

[userenv]

[userenv.shared]
ARCHIVE_RAW_HTML_ENABLED = "true"
